# Variáveis de ambiente do painel-aponte.
# Configure estas no Vercel (Settings → Environment Variables).
# NUNCA comite os valores reais — este arquivo só documenta os nomes.

# --- Conta Azul (Portal do Desenvolvedor) ---
CA_CLIENT_ID=seu_client_id
CA_CLIENT_SECRET=seu_client_secret
CA_REDIRECT_URI=https://painel-aponte.vercel.app/api/auth/callback
CA_ACCOUNT_KEY=aponte

# Chave que protege os endpoints de setup (/api/auth/start e /inspecionar).
# Crie uma senha forte qualquer.
CA_SETUP_SECRET=uma_senha_forte_aqui

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_publica
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_secreta
